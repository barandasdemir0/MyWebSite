
@{
    Layout = null;
    var provider = (string?)ViewBag.provider ?? "Email";
    var isEmail = provider == "Email";
}

<!DOCTYPE html>
<html lang="tr">

<head>
    <script src="js/theme-init.js"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>İki Aşamalı Doğrulama Yöntemi Seç | Admin Panel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/Mytheme/admin/css/modules/variables.css?v=1.0">
    <link rel="stylesheet" href="/Mytheme/admin/css/modules/global.css?v=1.0">
    <link rel="stylesheet" href="/Mytheme/admin/css/modules/layout.css?v=1.0">
    <link rel="stylesheet" href="/Mytheme/admin/css/modules/components.css?v=1.0">
    <link rel="stylesheet" href="/Mytheme/admin/css/modules/notifications.css?v=1.0">
    <link rel="stylesheet" href="/Mytheme/admin/css/modules/login.css?v=1.0">
    <link rel="stylesheet" href="/Mytheme/admin/css/modules/choose-two-factor.css?v=1.0">
    <link rel="stylesheet" href="/Mytheme/admin/css/modules/preloader.css">
</head>

<body class="login-page choose-two-factor-page">
   

<div class="login-container">
    <div class="login-box">
        <div class="header-actions"></div>

        <div class="login-logo">
            <h1><span>Admin</span> Panel</h1>
            <p>6 haneli güvenlik kodunu girin</p>
        </div>

        <form asp-action="VerifyTwoFactor" method="post" autocomplete="one-time-code">
            <div class="form-group">
                    <label for="code">
                        @(isEmail ? "E-posta ile gelen kod" : "Google Authenticator kodu")
                    </label>
                <div asp-validation-summary="All" class="text-danger"></div>
                <input type="text" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" class="form-control"
                       name="code" placeholder="000000" required>
                    <small>
                        @(isEmail
                            ? "Kodu 5 dakika içinde girin."
                            : "Google Authenticator uygulamasındaki 6 haneli kodu girin.")
                    </small>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="fas fa-shield-alt"></i>
                Devam Et
            </button>

                @if (isEmail)
                {
                    <div class="form-group mt-12">
                        <a asp-action="SendEmailCode">Kodu tekrar gönder</a>
                    </div>
                }
        </form>

        <div class="security-section">
            <p><i class="fas fa-lock"></i> Hesabınız iki aşamalı doğrulama ile korunur.</p>
        </div>
    </div>
</div>
    <script src="/Mytheme/admin/js/modules/notifications.js"></script>
    <script src="/Mytheme/admin/js/modules/auth.js"></script>
    <script src="/Mytheme/admin/js/modules/ui.js"></script>
    <script src="/Mytheme/admin/js/admin.js"></script>
</body>

</html>