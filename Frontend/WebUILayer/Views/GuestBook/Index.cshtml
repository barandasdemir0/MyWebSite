@using SharedKernel.Shared
@using DtoLayer.GuestBookDtos
@model PagedResult<GuestBookListDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var guestUser = ViewBag.GuestUser as CreateGuestBookDto;
}

@section Styles {
    <link rel="stylesheet" href="/Mytheme/portfolio/css/sections/sections.css">

    <link rel="stylesheet" href="/Mytheme/portfolio/css/sections/guestbook.css">
}

<!-- PAGE HEADER -->
<section class="section guestbook-header-section">
    <div class="container">
        <div class="section-header" data-aos="fade-up">
            <p class="section-subtitle">Topluluk</p>
            <h1 class="section-title">Ziyaretçi <span class="gradient-text">Defteri</span></h1>
            <div class="section-line"></div>
            <p class="text-center mt-3 section-header-subtitle">
                Ziyaretçiler için bir hatıra duvarı. Düşüncelerinizi paylaşmak için GitHub ile giriş yapın veya bir
                not bırakın.
            </p>
        </div>
    </div>
</section>

<!-- GUESTBOOK SECTION -->
<section class="section guestbook-section">
    <div class="container guestbook-container">

        
        <!-- Başarı/Hata Mesajları -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success text-center mb-4" data-aos="fade-up">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger text-center mb-4" data-aos="fade-up">@TempData["ErrorMessage"]</div>
        }

        @if (guestUser == null)
        {
            <!-- Auth / Sign In Call to Action -->
            <div class="guestbook-auth" data-aos="fade-up">
                <p class="auth-text">Yorum bırakmak için sosyal medya hesaplarınızla giriş yapmanız gerekmektedir.</p>
                <div class="auth-buttons">
                    <a asp-action="LoginGithub" asp-controller="OAuth" class="btn-github">
                        <i class="fab fa-github"></i> GitHub ile Giriş
                    </a>
                    <a asp-action="LoginLinkedin" asp-controller="OAuth" class="btn-linkedin">
                        <i class="fab fa-linkedin"></i> LinkedIn ile Giriş
                    </a>
                </div>
            </div>

            <!-- Comment Form (Simulated) -->
            <div class="guestbook-form" data-aos="fade-up" data-aos-delay="100">
                <div class="form-header">
                    <h3>Bir Not Bırakın</h3>
                    <p>Mesajlarınız moderasyon sonrası yayınlanacaktır.</p>
                </div>
                <form>
                    <div class="form-group">
                        <textarea class="form-control" id="guestbookMessage" name="message" rows="4"
                                  placeholder="Mesajınız..."></textarea>
                    </div>
                    <div class="text-center">
                        <button type="button" class="btn-primary-custom form-submit-btn" disabled
                                title="Giriş yapmalısınız">
                            <i class="fas fa-paper-plane me-2"></i>Gönder
                        </button>
                    </div>
                </form>
            </div>
        }
        else
        {
            <!-- Auth / Sign In Call to Action -->
            <div class="guestbook-auth" data-aos="fade-up">
                <p class="auth-text">Yorum bırakmak için sosyal medya hesaplarınızla giriş yapmanız gerekmektedir.</p>
                <div class="auth-buttons">
                    <a asp-action="LoginGithub" asp-controller="OAuth" class="btn-github">
                        <i class="fab fa-github"></i> GitHub ile Giriş
                    </a>
                    <a asp-action="LoginLinkedin" asp-controller="OAuth" class="btn-linkedin">
                        <i class="fab fa-linkedin"></i> LinkedIn ile Giriş
                    </a>
                </div>
            </div>

            <!-- Comment Form (Simulated) -->
            <div class="guestbook-form" data-aos="fade-up" data-aos-delay="100">
                <div class="form-header">
                    <h3>Bir Not Bırakın</h3>
                    <p>Mesajlarınız moderasyon sonrası yayınlanacaktır.</p>
                </div>
                <form>
                    <div class="form-group">
                        <textarea class="form-control" id="guestbookMessage" name="message" rows="4"
                                  placeholder="Mesajınız..."></textarea>
                    </div>
                    <div class="text-center">
                        <button type="button" class="btn-primary-custom form-submit-btn"
                                title="Giriş yapmalısınız">
                            <i class="fas fa-paper-plane me-2"></i>Gönder
                        </button>
                    </div>
                </form>
            </div>
        }

       

        <!-- Comments List -->
        <div class="comments-list mt-5">
            <h3 class="mb-4">Son Mesajlar (@Model.TotalCount)</h3>

            @if (!Model.Items.Any())
            {
                <p class="text-muted" data-aos="fade-up">Henüz onaylanmış mesaj bulunmuyor. İlk yazan siz olun!</p>
            }

            @{
                int delay = 200;
            }
            @foreach (var item in Model.Items)
            {
                <div class="comment-card" data-aos="fade-up" data-aos-delay="@delay">
                    <div class="comment-avatar">
                        <img src="@item.AuthorAvatarUrl" alt="@item.AuthorName">
                    </div>
                    <div class="comment-content">
                        <div class="comment-header">
                            <div class="comment-author">
                                @item.AuthorName
                                <span>Guest</span>
                            </div>
                            <div class="comment-date">@item.CreatedAt.AddHours(3).ToString("dd MMM yyyy HH:mm")</div>
                        </div>
                        <p class="comment-text">
                            @item.Message
                        </p>
                    </div>
                </div>
                delay += 100;
            }
        </div>

        <!-- Pagination (Senin Özel ViewComponentin) -->
        <div class="mt-4" data-aos="fade-up">
            @await Component.InvokeAsync("LayoutPublicPagination", new { currentPage = Model.PageNumber, totalPages = Model.TotalPages })
        </div>
    </div>
</section>



<!-- Guestbook Success Modal -->
<div class="success-modal" id="guestbookSuccessModal">
    <div class="modal-content success-modal-content">
        <div class="modal-header success-modal-header">
            <div class="success-icon">
                <i class="fas fa-check"></i>
            </div>
        </div>
        <div class="modal-body success-modal-body">
            <h2>Mesajınız Gönderildi! 🎉</h2>
            <p>Yorumunuz başarıyla kaydedilmiştir. Moderasyon sonrası yayınlanacaktır.</p>
        </div>
        <div class="modal-footer success-modal-footer">
            <button class="btn-primary-custom close-modal">
                <i class="fas fa-check me-2"></i>Tamam
            </button>
        </div>
    </div>
</div>


@section Scripts {
    <script src="/Mytheme/portfolio/js/guestbook.js"></script>
}