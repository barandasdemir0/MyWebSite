@model Setup2FAResultDto
@using DtoLayer.AuthDtos
@{
    ViewData["Title"] = "Authenticator Kurulumu";
    ViewData["BodyClass"] = "security-page";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section styles {
    <link rel="stylesheet" href="~/Mytheme/admin/css/modules/security.css">
}

<div class="content-grid">
    <div class="card card-two-factor">
        <div class="card-header">
            <h3><i class="fas fa-mobile-alt"></i>Authenticator Kurulumu</h3>
        </div>
        <div class="card-body-two-factor">
            <p class="two-factor-desc">Google Authenticator veya Authy uygulamanızla QR kodu tarayın:</p>

            <div class="two-factor-method">
                <img src="@Model.QrCodeImageBase64" alt="QR Kod" class="qr-code-image">
            </div>

            <p class="two-factor-desc">QR tarayamıyorsanız bu kodu elle girin:</p>
            <div class="two-factor-method">
                <span class="two-factor-method-label">Manuel Kod:</span>
                <span class="two-factor-method-value">@Model.ManuelEntryKey</span>
            </div>

            <form asp-area="Admin" asp-controller="Security" asp-action="ConfirmAuthenticator" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label>Uygulamadaki 6 haneli kodu girin</label>
                    <input type="text" class="form-control" name="code"
                           maxlength="6" pattern="[0-9]{6}" inputmode="numeric"
                           placeholder="000000" required>
                </div>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-check"></i> Onayla ve 2FA'yı Aç
                </button>
            </form>

            <div class="two-factor-actions">
                <a href="/Admin/Security/Index" class="btn-ghost">
                    <i class="fas fa-arrow-left"></i> Geri dön
                </a>
            </div>
        </div>
    </div>
</div>
