@model List<PendingUserDto>
@{
    ViewData["Title"] = "PendingUser";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@section styles {
    <link rel="stylesheet" href="/Mytheme/admin/css/modules/table-variations.css">
}

<div class="card mt-25">
    <div class="card-header">
        <h3> Onay Bekleyen Kullanıcılar</h3>
        <input type="text" class="form-control filter-search" placeholder="Kullanıcı ara...">
    </div>
    @if (Model.Count == 0)
    {
        <p>Onay Bekleyen Kullanıcı Yok</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Ad</th>
                        <th>SoyAd</th>
                        <th>E-posta</th>
                        <th>Kayıt Tarihi</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Surname</td>
                            <td>@item.Email</td>
                            <td data-label="Rol"><span class="status-badge role-admin">İzin isteyen kullanıcı</span></td>
                            <td data-label="Son Giriş">@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td data-label="Durum"><span class="status-badge active">Aktif</span></td>
                            <td data-label="İşlemler">
                                <div class="action-btns">
                                    <form asp-action="Approve" asp-route-id="@item.UserId" method="post">
                                        <button type="submit" class="btn btn-success btn-sm">
                                            <i class="fas fa-check"></i> Onayla
                                        </button>
                                    </form>
                                    
                                   @*  <button class="action-btn delete" title="Sil"><i class="fas fa-trash"></i></button> *@
                                </div>
                            </td>
                        </tr>
                    }
            
                  
          
                </tbody>
            </table>
        </div>
    }
</div>
@section scripts {
    <script src="/Mytheme/admin/js/modules/table-previews.js"></script>
}


